    {
      "name": "3. Tasks",
      "item": [
        {
          "name": "Criar Task",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implementar testes unitários\",\n  \"description\": \"Cobrir BoardService com JUnit\",\n  \"boardId\": \"BOARD_UUID_AQUI\",\n  \"status\": \"PENDING\",\n  \"priority\": \"HIGH\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks"
              ]
            }
          }
        },
        {
          "name": "Listar/Filtrar Tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks?boardId=&status=PENDING&search=testes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks"
              ],
              "query": [
                {
                  "key": "boardId",
                  "value": ""
                },
                {
                  "key": "status",
                  "value": "PENDING"
                },
                {
                  "key": "assignedUserId",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "testes"
                }
              ]
            }
          }
        },
        {
          "name": "Atualizar Task Parcial",
          "request": {
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"CRITICAL\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "TASK_UUID_AQUI"
                }
              ]
            }
          }
        },
        {
          "name": "Deletar Task",
          "request": {
            "method": "DELETE",
            "header": [],
